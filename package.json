{
  "name": "mi-coach",
  "version": "1.0.0",
  "private": true,
  "description": "Powerbuilding Coach — app local para registrar entrenamientos",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "start": "npm run start --workspace server",
    "serve": "node server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
